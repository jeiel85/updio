{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "updio",
  "version": "0.3.3",
  "identifier": "com.jeiel85.updio",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Vibe Video Upscaler",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://localhost:* http://127.0.0.1:*;"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "jeiel85",
    "copyright": "Copyright (c) 2026 jeiel85",
    "license": "MIT",
    "licenseFile": "../LICENSE",
    "resources": {
      "../LICENSE": "LICENSE",
      "../THIRD_PARTY_NOTICES.md": "THIRD_PARTY_NOTICES.md",
      "../third-party-licenses/**/*": "third-party-licenses/"
    },
    "externalBin": [
      "binaries/vibe-engine",
      "binaries/ffmpeg",
      "binaries/ffprobe"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
